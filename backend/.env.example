# InnerSpark Environment Variables

# MongoDB Configuration
MONGODB_URL=your-mongodb-connection-string-here

# Server Configuration
PORT=your-server-port-here
NODE_ENV=your-environment-here

# JWT Secret (Change this to a random secure string)
JWT_SECRET=your-jwt-secret-here

# Frontend Configuration
CLIENT_URL=your-frontend-url-here

# Email Configuration (EmailJS SMTP)
# Service ID for EmailJS
EMAILJS_SERVICE_ID=your-emailjs-service-id-here

# SMTP Settings (Configure with your email provider)
# For Gmail: Enable 2-Step Verification and create an App Password
# App Password: https://myaccount.google.com/apppasswords
SMTP_HOST=your-smtp-host-here
SMTP_PORT=your-smtp-port-here
SMTP_USER=your-smtp-user-here
SMTP_PASS=your-smtp-password-here

# Cloudflare R2 Configuration
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_BUCKET_NAME=your-bucket-name
R2_CUSTOM_DOMAIN=https://media.yourdomain.com
